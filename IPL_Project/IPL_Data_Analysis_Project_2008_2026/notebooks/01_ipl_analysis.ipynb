   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "predictor = model.build_match_predictor()\n",
    "print(f'Model Accuracy: {predictor["accuracy"]:.3f}')\n",
    "print('\nFeature Importance:')\n",
    "for feat, imp in sorted(predictor['feature_importance'].items(), key=lambda x: x[1], reverse=True):\n",
