   "source": [
    "# IPL Data Analysis Project (2008-2026)\n",
    "## Comprehensive Analytics Notebook\n",
    "\n",
    "This notebook demonstrates the complete IPL analysis pipeline."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from matplotlib.gridspec import GridSpec\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Import the analytics model\n",
    "import sys\n",
    "sys.path.append('../src')\n",
    "from ipl_analytics import IPLAnalyticsModel, load_data, run_full_analysis\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "print('Setup complete!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load all datasets\n",
    "matches, batting, bowling, pitch, points = load_data('../data/raw')\n",
    "\n",
    "print(f'Matches: {matches.shape}')\n",
    "print(f'Batting: {batting.shape}')\n",
    "print(f'Bowling: {bowling.shape}')\n",
    "print(f'Pitch: {pitch.shape}')\n",
    "print(f'Points: {points.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Initialize Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = IPLAnalyticsModel(matches, batting, bowling, pitch, points)\n",
    "print('Model initialized!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Toss Impact Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "toss_impact = model.analyze_toss_impact()\n",
    "print(f\"Overall toss advantage: {toss_impact['toss_winner_won'].sum() / toss_impact['total_matches'].sum() * 100:.1f}%\")\n",
    "toss_impact.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Best Players Per Season"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "best_batsmen = model.get_best_batsman_per_season()\n",
    "best_bowlers = model.get_best_bowler_per_season()\n",
    "\n",
    "print('Best Batsman Per Season:')\n",
    "print(best_batsmen[['season', 'player', 'team', 'runs', 'impact_score']])\n",
    "\n",
    "print('\nBest Bowler Per Season:')\n",
    "print(best_bowlers[['season', 'player', 'team', 'wickets', 'economy', 'impact_score']])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Home vs Away Performance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "home_away = model.analyze_home_away()\n",
    "home_away.sort_values('advantage', ascending=False)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
